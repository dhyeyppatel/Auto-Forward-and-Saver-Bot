# ─────────────────────────────────────────────────────────────────
#  .env.example — Template for required environment variables
#  Copy this to .env for local development (never commit .env!)
# ─────────────────────────────────────────────────────────────────

# ── Telegram Bot Credentials ─────────────────────────────────────
# Get from: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Get from: https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=your_api_hash_here

# ── MongoDB Atlas ─────────────────────────────────────────────────
# 1. Create a free M0 cluster at https://cloud.mongodb.com
# 2. Go to: Cluster → Connect → Drivers → Python
# 3. Copy the connection string, replace <password> with your DB user password
# NOTE: Do NOT add a database name to the URI path.
#       The bot automatically uses its own isolated database named "tg_forwardbot".
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Session Encryption Key ────────────────────────────────────────
# Generate a new key ONCE and keep it safe. If you lose this key,
# all stored sessions become unreadable and users must re-login.
#
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here
